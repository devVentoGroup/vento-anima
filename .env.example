# ==========================================
# VENTO OS - Environment Variables Template
# ==========================================
# 
# Copia este archivo como:
# - .env.local (desarrollo local)
# - .env.production (producción)
# 
# Reemplaza los valores con los tuyos reales

# ==========================================
# 🌍 APLICACIÓN - URLs Públicas
# ==========================================

# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL base del API (si es diferente de APP_URL)
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ==========================================
# 🔐 SUPABASE - Base de Datos y Autenticación
# ==========================================

# Obtén estos valores en: https://app.supabase.com
# Project Settings → API

# URL del proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima (pública, segura para exponer)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...tu-anon-key...

# Clave de servicio (SECRETA, NO compartir)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...tu-service-key...

# ==========================================
# 🔑 GOOGLE OAUTH
# ==========================================

# Obtén estos valores en: https://console.cloud.google.com
# 1. Crear proyecto
# 2. OAuth 2.0 → Credentials → Create OAuth client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs:
#    - http://localhost:3000/auth/callback/google (desarrollo)
#    - https://tu-dominio.com/auth/callback/google (producción)

NEXT_PUBLIC_GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret-aqui

# ==========================================
# 💳 STRIPE - Pagos (Opcional)
# ==========================================

# Obtén estos valores en: https://dashboard.stripe.com/apikeys

# Clave pública (segura para exponer)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta (NO compartir)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret para verificar eventos
STRIPE_WEBHOOK_SECRET=whsec_test_...

# ==========================================
# 📊 GOOGLE ANALYTICS (Opcional)
# ==========================================

# Obtén este ID en: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==========================================
# 🚨 SENTRY - Error Tracking (Opcional)
# ==========================================

# Obtén el DSN en: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/123456

# ==========================================
# 📧 EMAIL - Envío de Correos (Opcional)
# ==========================================

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxx

# O usar Resend
RESEND_API_KEY=re_xxxxxxxxxxxxx

# ==========================================
# 🗄️ BASE DE DATOS - Backup y Migraciones
# ==========================================

# URL completa de la BD (para migraciones)
DATABASE_URL=postgresql://user:password@localhost:5432/vento_os

# ==========================================
# 🔒 SEGURIDAD
# ==========================================

# Para firmar tokens JWT (en bytes)
NEXTAUTH_SECRET=tu-secreto-aleatorio-super-seguro

# URL de la aplicación para NextAuth
NEXTAUTH_URL=http://localhost:3000

# ==========================================
# 🛠️ DESARROLLO
# ==========================================

# Mostrar logs detallados
DEBUG=false

# Ambiente
NODE_ENV=development

# ==========================================
# 📌 NOTAS IMPORTANTES
# ==========================================
#
# 1. NUNCA commitear valores sensibles al git
# 2. Las variables con NEXT_PUBLIC_ se exponen al cliente
# 3. Las variables sin prefijo son solo server-side
# 4. Para producción, usar un secrets manager
# 5. Verificar .gitignore incluya archivos .env*
#
# .gitignore debe incluir:
# .env.local
# .env.*.local
# .env.production.local
#
