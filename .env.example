# Supabase
EXPO_PUBLIC_SUPABASE_URL=tu_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key

# Redirect para invitaciÃ³n y Â«Â¿Olvidaste tu contraseÃ±a?Â» (pÃ¡gina web set-password en Vercel). Obligatorio para staff-invitations-create.
# EXPO_PUBLIC_ANIMA_AUTH_REDIRECT_URL=https://tu-proyecto.vercel.app/api/set-password
# En Supabase Edge Functions (Secrets): SET_PASSWORD_WEB_URL = misma URL; RESEND_API_KEY = clave Resend; ANIMA_INVITE_FROM_EMAIL = ej. ANIMA <noreply@tudominio.com>

# Cuenta de revisiÃ³n (Apple/Google) â€” allowlist de emails que usan password fijo
EXPO_PUBLIC_REVIEW_EMAILS=test@ventogroup.com
EXPO_PUBLIC_REVIEW_PASSWORD=TestPass123

# Activa override solo para builds de revisión (dejar false en operación normal)
EXPO_PUBLIC_REVIEW_PASSWORD_OVERRIDE_ENABLED=false

# UID exacto autorizado para eliminar trabajadores desde Equipo (UI)
EXPO_PUBLIC_ANIMA_OWNER_DELETE_UID=tu_uid_owner

# En Supabase Edge Functions (Secrets), definir:
# ANIMA_OWNER_DELETE_UID=tu_uid_owner

# Sentry (error/crash monitoring)
EXPO_PUBLIC_SENTRY_DSN=https://tu_dsn_publico@o000000.ingest.sentry.io/0000000
SENTRY_ORG=tu_org_slug
SENTRY_PROJECT=anima-mobile
# No subir este valor al repo real. Configuralo en EAS como secret.
SENTRY_AUTH_TOKEN=sntrys_tu_token
